        <dependency>
            <groupId>ch.admin.bit.jeap</groupId>
            <artifactId>jeap-messaging-infrastructure-kafka</artifactId>
        </dependency>
        <dependency>
            <groupId>ch.admin.bit.jeap</groupId>
            <artifactId>jeap-messaging-outbox</artifactId>
        </dependency>
        <!-- Messages -->
        <dependency>
            <groupId>ch.admin.bj.swiyu.messagetype.ti</groupId>
            <artifactId>ti-vc-schema-submission-accepted-event</artifactId>
            <version>6.0.0</version>
        </dependency>
        <dependency>
