        </dependency>
        <dependency>
            <groupId>ch.admin.bj.swiyu.messagetype.ti</groupId>
            <artifactId>ti-trust-onboarding-submission-accepted-event</artifactId>
            <version>4.0.1</version>
        </dependency>
        <dependency>
            <groupId>ch.admin.bj.swiyu.messagetype.ti</groupId>
            <artifactId>ti-trust-add-did-submission-submitted-event</artifactId>
            <version>1.0.0</version>
        </dependency>
        <dependency>
            <groupId>ch.admin.bj.swiyu.messagetype.ti</groupId>
            <artifactId>ti-trust-add-did-submission-accepted-event</artifactId>
            <version>1.0.0</version>
        </dependency>
        <dependency>
            <groupId>ch.admin.bj.swiyu.messagetype.ti</groupId>
            <artifactId>ti-trust-add-did-submission-rejected-event</artifactId>
