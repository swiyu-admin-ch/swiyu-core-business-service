    </parent>
    <artifactId>swiyu-core-business-service-app</artifactId>
    <packaging>jar</packaging>

    <properties>
        <sonar.exclusions>
            src/main/java/ch/admin/bj/swiyu/core/business/common/config/OpenApiConfig.java,
            src/main/java/ch/admin/bj/swiyu/core/business/common/config/FeatureFlags.java,
            **/*Exception.java,
            **/*Dto.java
        </sonar.exclusions>
        <sonar.coverage.exclusions>
            src/main/java/ch/admin/bj/swiyu/core/business/modules/dataimport/**/*
        </sonar.coverage.exclusions>
        <!-- dependency versions -->
        <nimbus-jose-jwt.version>10.9.1</nimbus-jose-jwt.version>
        <jackson-databind-nullable.version>0.2.10</jackson-databind-nullable.version>
        <json-schema-validator.version>1.5.9</json-schema-validator.version>
        <openapi-generator-maven-plugin.version>7.23.0</openapi-generator-maven-plugin.version>
        <didresolver.version>2.8.2</didresolver.version>
        <openfeign.querydsl.version>7.4.0</openfeign.querydsl.version>
    </properties>

